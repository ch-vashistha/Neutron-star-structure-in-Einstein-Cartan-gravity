79733b9b1cf1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ruleKcon", "=", 
    RowBox[{"MakeRule", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"K", "[", 
         RowBox[{
          RowBox[{"-", "a"}], ",", "a", ",", "b"}], "]"}], ",", 
        RowBox[{"Kcon", "[", "b", "]"}]}], "}"}], ",", 
      RowBox[{"MetricOn", "\[Rule]", "All"}], ",", 
      RowBox[{"ContractMetrics", "\[Rule]", "True"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}]], "Input",
 CellChangeTimes->{{3.980490360556746*^9, 3.9804904108188677`*^9}, 
   3.9804904552332983`*^9},
 CellLabel->"In[74]:=",ExpressionUUID->"dddb35a9-0d49-4815-a8b8-3979ed253855"],

