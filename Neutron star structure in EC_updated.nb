Cell[TextData[{
 "Now, multiply both sides by epsilon tensor, and define:  ",
 Cell[BoxData[GridBox[{
    {
     RowBox[{"2", "\[Kappa]", " ", 
      SubscriptBox["\[Epsilon]", 
       RowBox[{" ", GridBox[{
          {"\[Sigma]\[Alpha]", "\[Beta]", "\[Gamma]"}
         },
         GridBoxSpacings->{"Columns" -> {
             Offset[0.], {
              Offset[0.034999999999999996`]}, 
             Offset[0.]}, "Rows" -> {{
              Offset[0.]}}}]}]]}], 
     RowBox[{GridBox[{
        {"\[Tau]", 
         StyleBox[
          RowBox[{GridBox[{
             {"\[Alpha]", "\[Beta]", "\[Gamma]"},
             {" ", " ", " "}
            },
            GridBoxSpacings->{"Columns" -> {
                Offset[0.], {
                 Offset[0.034999999999999996`]}, 
                Offset[0.]}, "Rows" -> {{
                 Offset[0.]}}}], "="}],
          FontSize->Rational[39, 4]]}
       },
       GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Center}}},
       GridBoxSpacings->{"Columns" -> {
           Offset[0.27999999999999997`], {
            Offset[0.034999999999999996`]}, 
           Offset[0.27999999999999997`]}, "Rows" -> {
           Offset[0.2], {
            Offset[0.4]}, 
           Offset[0.2]}}], "2", "\[Kappa]", " ", 
      SubscriptBox[
       SuperscriptBox["\[Tau]", "*"], "\[Sigma]"]}]}
   },
   GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Center}}},
   GridBoxSpacings->{"Columns" -> {
       Offset[0.27999999999999997`], {
        Offset[0.034999999999999996`]}, 
