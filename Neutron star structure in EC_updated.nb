Cell[BoxData[{
 RowBox[{
  RowBox[{"DefTensor", "[", 
   RowBox[{
    RowBox[{"Kcon", "[", 
     RowBox[{"-", "a"}], "]"}], ",", " ", "M", ",", " ", 
    RowBox[{"PrintAs", "\[Rule]", "\"\<K\>\""}]}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
