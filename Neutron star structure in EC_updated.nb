Cell[TextData[{
 "This can be identified as the first term of tempMet1. Also variational \
derivative of \[Eta]  vanishes (no metric dependence). \n",
 StyleBox["Hence, epsilong behaves correctly. ",
  FontWeight->"Bold"]
}], "Text",
