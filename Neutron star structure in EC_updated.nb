   RowBox[{"DefTensor", "[", 
    RowBox[{
     RowBox[{"Ktil", "[", 
      RowBox[{"-", "a"}], "]"}], ",", " ", "M", ",", " ", 
     RowBox[{
     "PrintAs", "\[Rule]", "\"\<\!\(\*SuperscriptBox[\(K\), \(*\)]\)\>\""}]}],
     "]"}], ";"}], " ", 
